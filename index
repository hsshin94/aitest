    XMLHttpRequest.prototype.open = function(method, url) {
        this._url = url;
        this._blocked = blockedPatterns.some(function(p) { return url.indexOf(p) !== -1; });
        if (!this._blocked) return origOpen.apply(this, arguments);
    };
    XMLHttpRequest.prototype.send = function() {
        if (this._blocked) {
            var self = this;
            Object.defineProperty(self, 'readyState', { get: function() { return 4; } });
            Object.defineProperty(self, 'status', { get: function() { return 200; } });
            Object.defineProperty(self, 'responseText', { get: function() {
                if (self._url && self._url.indexOf('guestbook') !== -1)
                    return JSON.stringify({"status":"OK","message":"","data":[],"recordsTotal":null});
                return JSON.stringify({"status":"OK"});
            }});
            setTimeout(function() {
                if (typeof self.onreadystatechange === 'function') self.onreadystatechange();
                if (typeof self.onload === 'function') self.onload();
            }, 0);
            return;
        }
        return origSend.apply(this, arguments);
    };
    $(document).ajaxSend(function(event, jqxhr, settings) {
        if (blockedPatterns.some(function(p) { return settings.url.indexOf(p) !== -1; })) jqxhr.abort();
    });
})();
